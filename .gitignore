# Jekyll / GitHub Pages local build output
_site/
.jekyll-cache/
.jekyll-metadata

# OS and editor cruft
.DS_Store
*.swp

# Local tooling indexes and caches
.tokensave/
.context/
.aislop/

# tessl / coding-agent local install state (machine-specific, not committed).
# The plugin definition under .agents/ IS tracked; these are transient install
# artefacts created by `tessl install` / project init.
.tessl/
tessl.json
.mcp.json
.cursor/
.gemini/
.codex/

# This project intentionally tracks files that the user's global ~/.gitignore
# excludes (mise.toml, .agents/). Re-include them here.
!mise.toml
!.agents/
!.agents/**

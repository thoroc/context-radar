{
  "name": "context-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive comparison catalogue and stack builder for context-reduction tools, built with Vite and TypeScript.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src plugins vite.config.ts",
    "lint:fix": "biome check --write src plugins vite.config.ts",
    "format": "biome format --write src plugins vite.config.ts"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.19.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}

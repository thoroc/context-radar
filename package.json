{
  "name": "context-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive comparison catalogue and stack builder for context-reduction tools, built with Vite and TypeScript.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src plugins scripts vite.config.ts",
    "lint:fix": "biome check --write src plugins scripts vite.config.ts",
    "format": "biome format --write src plugins scripts vite.config.ts",
    "validate": "bun scripts/validate-data.ts",
    "data:add": "bun scripts/data-add.ts",
    "gen:schema": "bun scripts/gen-schema.ts",
    "gen:icons": "bun scripts/gen-icons.ts",
    "freshness": "bun scripts/check-freshness.ts",
    "freshness:sync": "bun scripts/sync-freshness-issue.ts"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.0",
    "@tabler/icons": "^3.44.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "yaml": "^2.6.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  }
}

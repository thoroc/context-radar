{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pantheon-org/context-radar/schema/tool-record.schema.json",
  "title": "context-radar tool record",
  "description": "One tool record in data/context-reduction-tools.json. Generated from src/lib/schema.ts via `mise run gen:schema` — do not edit by hand.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "githubUrl": {
      "type": "string",
      "format": "uri"
    },
    "layer": {
      "type": "string",
      "enum": [
        "Shell output",
        "All tool output",
        "Static context injection (push model)",
        "Conversation history management",
        "Personal knowledge retrieval",
        "Library documentation retrieval",
        "Codebase understanding & onboarding",
        "Code navigation",
        "Architecture violation detection",
        "MCP definition tokens",
        "Cross-session governance",
        "Response verbosity + memory compression",
        "Config stack audit",
        "Agent safety enforcement",
        "Tabular data retrieval",
        "Agent runtime & context orchestration",
        "Universal context compression middleware",
        "Reference resource (curated list)",
        "Agent memory persistence",
        "Code generation minimalism (YAGNI enforcement)"
      ]
    },
    "whatItDoes": {
      "type": "string"
    },
    "conflict": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "hard",
            "soft",
            "either-or",
            "stackable",
            "none"
          ]
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "caveated",
                "refuted",
                "unverified"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkedOn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "evidenceType": {
                    "type": "string",
                    "enum": [
                      "source-code",
                      "official-docs",
                      "readme",
                      "release",
                      "search",
                      "third-party"
                    ]
                  }
                },
                "required": [
                  "url",
                  "quote",
                  "checkedOn",
                  "evidenceType"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "status",
            "sources"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "severity",
        "projects"
      ],
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "languages": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "rust",
              "python",
              "typescript",
              "javascript",
              "node",
              "go",
              "powershell",
              "shell",
              "lua",
              "gleam",
              "none"
            ]
          }
        },
        "detail": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "caveated",
                "refuted",
                "unverified"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkedOn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "evidenceType": {
                    "type": "string",
                    "enum": [
                      "source-code",
                      "official-docs",
                      "readme",
                      "release",
                      "search",
                      "third-party"
                    ]
                  }
                },
                "required": [
                  "url",
                  "quote",
                  "checkedOn",
                  "evidenceType"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "status",
            "sources"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "languages"
      ],
      "additionalProperties": false
    },
    "requirements": {
      "type": "string"
    },
    "requiresExternal": {
      "default": false,
      "type": "boolean"
    },
    "licence": {
      "type": "object",
      "properties": {
        "spdx": {
          "type": "string",
          "minLength": 1
        },
        "warning": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "caveated",
                "refuted",
                "unverified"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkedOn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "evidenceType": {
                    "type": "string",
                    "enum": [
                      "source-code",
                      "official-docs",
                      "readme",
                      "release",
                      "search",
                      "third-party"
                    ]
                  }
                },
                "required": [
                  "url",
                  "quote",
                  "checkedOn",
                  "evidenceType"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "status",
            "sources"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "spdx"
      ],
      "additionalProperties": false
    },
    "stars": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "trend": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "activity": {
      "type": "object",
      "properties": {
        "contributors": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "latestVersion": {
          "type": "string"
        },
        "releaseCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "releasedOn": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "corroboration": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "caveated",
                "refuted",
                "unverified"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkedOn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "evidenceType": {
                    "type": "string",
                    "enum": [
                      "source-code",
                      "official-docs",
                      "readme",
                      "release",
                      "search",
                      "third-party"
                    ]
                  }
                },
                "required": [
                  "url",
                  "quote",
                  "checkedOn",
                  "evidenceType"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "status",
            "sources"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "activityStatus": {
      "type": "object",
      "properties": {
        "band": {
          "type": "string",
          "enum": [
            "active",
            "stable",
            "slowing",
            "early",
            "dormant",
            "none"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "band",
        "label"
      ],
      "additionalProperties": false
    },
    "verdict": {
      "type": "object",
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "best",
            "add",
            "add-if",
            "either-or",
            "watch",
            "reference",
            "drop"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "confirmed",
                "caveated",
                "refuted",
                "unverified"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "quote": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkedOn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "evidenceType": {
                    "type": "string",
                    "enum": [
                      "source-code",
                      "official-docs",
                      "readme",
                      "release",
                      "search",
                      "third-party"
                    ]
                  }
                },
                "required": [
                  "url",
                  "quote",
                  "checkedOn",
                  "evidenceType"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "status",
            "sources"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "decision",
        "rationale"
      ],
      "additionalProperties": false
    },
    "decisionRule": {
      "type": "string"
    },
    "extraClaims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "benchmark",
              "feature"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "caveated",
                  "refuted",
                  "unverified"
                ]
              },
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "quote": {
                      "type": "string",
                      "minLength": 1
                    },
                    "checkedOn": {
                      "type": "string",
                      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                    },
                    "evidenceType": {
                      "type": "string",
                      "enum": [
                        "source-code",
                        "official-docs",
                        "readme",
                        "release",
                        "search",
                        "third-party"
                      ]
                    }
                  },
                  "required": [
                    "url",
                    "quote",
                    "checkedOn",
                    "evidenceType"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "status",
              "sources"
            ],
            "additionalProperties": false
          },
          "proofLedger": {
            "type": "string",
            "enum": [
              "PROVEN",
              "SUPPORTED",
              "OPEN",
              "REJECTED"
            ]
          }
        },
        "required": [
          "kind",
          "label",
          "statement",
          "evidence"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "id",
    "tool",
    "githubUrl",
    "layer",
    "whatItDoes",
    "conflict",
    "runtime",
    "requirements",
    "requiresExternal",
    "licence",
    "stars",
    "trend",
    "activity",
    "activityStatus",
    "verdict",
    "decisionRule"
  ],
  "additionalProperties": false
}
